# ── Root-level .env.example ────────────────────────────────────────────────────
# Copy to apps/api/.env and fill in values before running.

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/seou_up_db
DATABASE_PASSWORD=password

# Security (MUST change JWT_SECRET_KEY in production)
JWT_SECRET_KEY=change-me-to-a-very-long-random-string-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Simulation: "mock" (default) → "mediapipe" (Phase 4)
SIMULATION_ADAPTER=mock

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=10

# Stripe — Individual Pro plans
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_FEATURED=price_...   # $29/mo Featured Pro (individual)

# Stripe — B2B Clinic plans
STRIPE_PRICE_ID_CLINIC_BASIC=price_...   # $49/mo Basic Clinic (up to 3 staff)
STRIPE_PRICE_ID_CLINIC_PRO=price_...     # $99/mo Pro Clinic (unlimited)
STRIPE_WEBHOOK_SECRET_CLINIC=whsec_...   # Separate webhook secret for /api/clinics/webhook

# App
APP_ENV=development
DEBUG=true
APP_BASE_URL=http://localhost:3000
