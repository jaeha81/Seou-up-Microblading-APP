# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/seou_up_db
DATABASE_PASSWORD=password

# ── Security ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-very-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Simulation ──────────────────────────────────────────────────────────────
# Keep as "mock" for MVP. Replace with "mediapipe" for Phase 4.
SIMULATION_ADAPTER=mock

# ── Queue ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OAuth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
KAKAO_REDIRECT_URI_KAKAO=http://localhost:8000/api/auth/kakao/callback

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Storage ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=10

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
