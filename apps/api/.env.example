# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/seou_up_db
DATABASE_PASSWORD=password

# ── Security ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-very-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Simulation ──────────────────────────────────────────────────────────────
# "mock"        — no AI, returns original image (default MVP)
# "huggingface" — free HF face-parsing API (requires HF_TOKEN)
# "mediapipe"   — local MediaPipe face mesh (requires mediapipe + opencv installed)
SIMULATION_ADAPTER=huggingface

# Hugging Face token — free at huggingface.co/join → Settings → Access Tokens
# Required when SIMULATION_ADAPTER=huggingface
HF_TOKEN=

# ── Queue ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OAuth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Storage ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=10

# ── Stripe (Phase 6 — Partner Paid Plans) ──────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create a recurring price in Stripe Dashboard, paste the price ID here
STRIPE_PRICE_ID_FEATURED=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
APP_BASE_URL=http://localhost:3000
